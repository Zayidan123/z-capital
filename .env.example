# Crypto Oracle AI - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/crypto_oracle

# ===========================================
# TELEGRAM BOT CONFIGURATION
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ===========================================
# ETHERSCAN API CONFIGURATION
# ===========================================
ETHERSCAN_API_KEY=your_etherscan_api_key_here
ETHERSCAN_BASE_URL=https://api.etherscan.io/api

# ===========================================
# CRYPTOPANIC API CONFIGURATION
# ===========================================
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1

# ===========================================
# BINANCE WEBSOCKET CONFIGURATION
# ===========================================
BINANCE_WS_URL=wss://stream.binance.com:9443/stream?streams=!ticker@arr

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Volume spike threshold (e.g., 300 means 300% increase)
VOLUME_SPIKE_THRESHOLD=300
# Time window for volume calculation in minutes
VOLUME_WINDOW_MINUTES=5
# Health check server port
HEALTH_CHECK_PORT=8080
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
